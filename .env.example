# Secrets — copy to .env and fill in. NEVER commit .env.

# Telegram (create a bot via @BotFather, then get your chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM provider API key (only the one matching config.yaml's llm.provider is needed)
# Gemini: https://aistudio.google.com/apikey  | Anthropic: https://console.anthropic.com
# OpenAI: https://platform.openai.com/api-keys
LLM_API_KEY=

# Startup Scout (Phase 2) — Hunter.io email finder (free tier)
HUNTER_API_KEY=
